local loadingComplete = false
local TOTAL_TIME = 20 * 60 -- 20 minutes

-- Dot Animation
local function animateLoading()
    local dots = 0
    while not loadingComplete do
        dots = (dots % 3) + 1
        subtitle.Text = "Loading" .. string.rep(".", dots)
        task.wait(0.45)
    end
end

-- Progress
local function startProgress()
    local startTime = tick()
    
    while not loadingComplete do
        local elapsed = tick() - startTime
        local progress = math.min(100, (elapsed / TOTAL_TIME) * 100)
        
        progressBar:TweenSize(UDim2.new(progress/100, 0, 1, 0), "Out", "Linear", 0.2, true)
        percentText.Text = math.floor(progress) .. "%"
        
        if progress >= 100 then
            break
        end
        task.wait(0.2)
    end
end

-- Finish Loading
local function finishLoading()
    if loadingComplete then return end
    loadingComplete = true
    subtitle.Text = "Welcome!"
    
    local tweenInfo = TweenInfo.new(1.2, Enum.EasingStyle.Quint, Enum.EasingDirection.Out)
    
    TweenService:Create(container, tweenInfo, {BackgroundTransparency = 1}):Play()
    TweenService:Create(title, tweenInfo, {TextTransparency = 1}):Play()
    TweenService:Create(subtitle, tweenInfo, {TextTransparency = 1}):Play()
    TweenService:Create(barContainer, tweenInfo, {BackgroundTransparency = 1}):Play()
    TweenService:Create(progressBar, tweenInfo, {BackgroundTransparency = 1}):Play()
    TweenService:Create(percentText, tweenInfo, {TextTransparency = 1}):Play()
    TweenService:Create(tip, tweenInfo, {TextTransparency = 1}):Play()
    
    task.wait(1.8)
    screenGui:Destroy()
end

-- Start
coroutine.wrap(animateLoading)()
startProgress()

-- Timer
task.spawn(function()
    task.wait(TOTAL_TIME)
    finishLoading()
end)

